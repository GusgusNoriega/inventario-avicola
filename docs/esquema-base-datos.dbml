// Modelo conceptual de Sistema Pollos.
// Importable en dbdiagram.io u otra herramienta compatible con DBML.

Enum estado_general {
  ACTIVO
  INACTIVO
}

Enum rol_tercero {
  CLIENTE
  PROVEEDOR
}

Enum tipo_operacion_precio {
  COMPRA
  VENTA
}

Enum canal_despacho {
  MAYORISTA
  BENEFICIADO
}

Enum origen_codigo_comprobante {
  ALEATORIO
  MANUAL
}

Enum estado_jornada {
  ABIERTA
  CERRADA
  ANULADA
}

Enum estado_ticket {
  BORRADOR
  ABIERTO
  CERRADO
  FACTURADO
  ANULADO
}

Enum origen_peso {
  BALANZA
  MANUAL
}

Enum estado_pesada {
  ACTIVA
  ANULADA
}

Enum sexo_pollo {
  MACHO
  HEMBRA
}

Enum tipo_movimiento {
  ENTRADA
  SALIDA
  TRANSFERENCIA
  DIRECTO
  AJUSTE
}

Enum estado_movimiento {
  BORRADOR
  CONFIRMADO
  ANULADO
}

Enum operacion_comprobante {
  COMPRA
  VENTA
}

Enum estado_comprobante {
  BORRADOR
  EMITIDO
  PAGADO
  ANULADO
}

Enum direccion_pago {
  COBRO
  PAGO
}

Enum estado_programacion_recepcion {
  BORRADOR
  PUBLICADA
  CERRADA
  CANCELADA
}

Enum estado_llegada_programada {
  PENDIENTE
  EN_ESPERA
  RECIBIENDO
  COMPLETADA
  NO_LLEGO
  CANCELADA
}

Table empresas {
  id bigint [pk, increment]
  razon_social varchar(180) [not null]
  nombre_comercial varchar(180)
  ruc varchar(20) [not null, unique]
  pais_codigo char(2) [not null, default: 'PE']
  moneda char(3) [not null, default: 'PEN']
  zona_horaria varchar(60) [not null, default: 'America/Lima']
  hora_corte_operativo time [not null, default: '21:00:00']
  sunat_habilitado boolean [not null, default: false]
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table sucursales {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  codigo varchar(30) [not null]
  nombre varchar(120) [not null]
  direccion varchar(250)
  zona_horaria varchar(60) [not null, default: 'America/Lima']
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, codigo) [unique]
  }
}

Table usuarios {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  sucursal_id bigint [ref: > sucursales.id]
  nombre varchar(150) [not null]
  email varchar(180) [not null]
  password_hash varchar(255) [not null]
  estado estado_general [not null, default: 'ACTIVO']
  ultimo_acceso_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, email) [unique]
  }
}

Table personal_access_tokens {
  id bigint [pk, increment]
  tokenable_type varchar(255) [not null]
  tokenable_id bigint [not null]
  name varchar(100) [not null]
  token char(64) [not null, unique, note: "Hash SHA-256; nunca guarda el token plano"]
  abilities text
  last_used_at timestamp
  expires_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (tokenable_type, tokenable_id)
    expires_at
  }
}

Table roles {
  id bigint [pk, increment]
  empresa_id bigint [ref: > empresas.id]
  codigo varchar(50) [not null]
  nombre varchar(100) [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, codigo) [unique]
  }
}

Table permisos {
  id bigint [pk, increment]
  codigo varchar(80) [not null, unique]
  descripcion varchar(200) [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table usuario_roles {
  usuario_id bigint [not null, ref: > usuarios.id]
  rol_id bigint [not null, ref: > roles.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (usuario_id, rol_id) [pk]
  }
}

Table rol_permisos {
  rol_id bigint [not null, ref: > roles.id]
  permiso_id bigint [not null, ref: > permisos.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (rol_id, permiso_id) [pk]
  }
}

Table terceros {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  tipo_documento varchar(20) [not null]
  numero_documento varchar(30) [not null]
  nombre_razon_social varchar(180) [not null]
  direccion varchar(250) [not null]
  telefono varchar(30)
  email varchar(180)
  observaciones text
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, numero_documento) [unique]
    (empresa_id, nombre_razon_social)
  }
}

Table tercero_roles {
  tercero_id bigint [not null, ref: > terceros.id]
  rol rol_tercero [not null]
  created_at timestamp [not null]

  indexes {
    (tercero_id, rol) [pk]
  }
}

Table almacenes {
  id bigint [pk, increment]
  sucursal_id bigint [not null, ref: > sucursales.id]
  codigo varchar(30) [not null]
  nombre varchar(120) [not null]
  direccion varchar(250)
  permite_stock_negativo boolean [not null, default: false]
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (sucursal_id, codigo) [unique]
  }
}

Table tipos_pollo {
  id bigint [pk, increment]
  codigo varchar(40) [not null, unique]
  nombre varchar(100) [not null]
  permite_despacho boolean [not null, default: true]
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table tipos_java {
  id bigint [pk, increment]
  codigo varchar(40) [not null, unique]
  nombre varchar(100) [not null]
  peso_kg decimal(12,3) [not null]
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table balanzas {
  id bigint [pk, increment]
  sucursal_id bigint [not null, ref: > sucursales.id]
  codigo varchar(30) [not null]
  nombre varchar(100) [not null]
  modo_conexion varchar(20)
  dispositivo varchar(180)
  configuracion json
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (sucursal_id, codigo) [unique]
  }
}

Table vehiculos {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  placa varchar(20) [not null]
  tercero_propietario_id bigint [ref: > terceros.id]
  conductor_habitual_id bigint [ref: > conductores.id]
  marca varchar(80)
  modelo varchar(80)
  color varchar(50)
  descripcion varchar(150)
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, placa) [unique]
  }
}

Table conductores {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  nombre varchar(150)
  dni varchar(20)
  telefono varchar(30)
  estado estado_general [not null, default: 'ACTIVO']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, dni) [unique]
    (empresa_id, nombre)
  }
}

Table proveedor_vehiculos {
  id bigint [pk, increment]
  proveedor_id bigint [not null, ref: > terceros.id]
  vehiculo_id bigint [not null, ref: > vehiculos.id]
  alias varchar(100)
  vigente_desde date [not null]
  vigente_hasta date
  estado estado_general [not null, default: 'ACTIVO']
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (proveedor_id, vehiculo_id, vigente_desde) [unique]
    (proveedor_id, estado)
    (vehiculo_id, estado)
  }
}

Table listas_precios {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  tercero_id bigint [ref: > terceros.id, note: "Vacío para una lista general"]
  codigo varchar(50) [not null]
  nombre varchar(120) [not null]
  operacion tipo_operacion_precio [not null]
  estado estado_general [not null, default: 'ACTIVO']
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, codigo) [unique]
    (tercero_id, operacion, estado)
  }
}

Table precios_historial {
  id bigint [pk, increment]
  lista_precio_id bigint [not null, ref: > listas_precios.id]
  tipo_pollo_id bigint [not null, ref: > tipos_pollo.id]
  precio_kg decimal(12,4) [not null]
  vigente_desde timestamp [not null]
  vigente_hasta timestamp
  motivo_cambio varchar(250)
  reemplaza_precio_id bigint [ref: > precios_historial.id]
  registrado_por bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]

  indexes {
    (lista_precio_id, tipo_pollo_id, vigente_desde) [unique]
    (lista_precio_id, tipo_pollo_id, vigente_hasta)
    (registrado_por, created_at)
  }
}

Table programaciones_recepcion {
  id bigint [pk, increment]
  sucursal_id bigint [not null, ref: > sucursales.id]
  fecha_operativa date [not null]
  estado estado_programacion_recepcion [not null, default: 'BORRADOR']
  observaciones text
  publicada_por bigint [ref: > usuarios.id]
  publicada_at timestamp
  cerrada_por bigint [ref: > usuarios.id]
  cerrada_at timestamp
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (sucursal_id, fecha_operativa) [unique]
    (sucursal_id, estado, fecha_operativa)
  }
}

Table programacion_recepcion_detalles {
  id bigint [pk, increment]
  programacion_id bigint [not null, ref: > programaciones_recepcion.id]
  proveedor_vehiculo_id bigint [not null, ref: > proveedor_vehiculos.id]
  conductor_id bigint [ref: > conductores.id]
  conductor_nombre_snapshot varchar(150)
  conductor_dni_snapshot varchar(20)
  numero_visita int [not null, default: 1]
  orden_llegada int
  hora_estimada time
  estado estado_llegada_programada [not null, default: 'PENDIENTE']
  observaciones text
  llegada_at timestamp
  recepcion_iniciada_at timestamp
  completada_at timestamp
  estado_actualizado_por bigint [ref: > usuarios.id]
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (programacion_id, proveedor_vehiculo_id, numero_visita) [unique]
    (programacion_id, estado, orden_llegada)
  }
}

Table jornadas_operativas {
  id bigint [pk, increment]
  sucursal_id bigint [not null, ref: > sucursales.id]
  fecha_operativa date [not null]
  estado estado_jornada [not null, default: 'ABIERTA']
  abierta_por bigint [not null, ref: > usuarios.id]
  inicio_at timestamp [not null]
  cierre_programado_at timestamp [not null]
  cerrada_por bigint [ref: > usuarios.id]
  cerrada_at timestamp
  observaciones text

  indexes {
    (sucursal_id, fecha_operativa) [unique]
    (sucursal_id, estado, cierre_programado_at)
  }
}

Table tickets_despacho {
  id bigint [pk, increment]
  jornada_id bigint [not null, ref: > jornadas_operativas.id]
  codigo varchar(40) [not null]
  canal canal_despacho [not null, default: 'MAYORISTA']
  cliente_destino_id bigint [ref: > terceros.id]
  almacen_destino_id bigint [ref: > almacenes.id]
  estado estado_ticket [not null, default: 'ABIERTO']
  observaciones text
  cerrado_por bigint [ref: > usuarios.id]
  cerrado_at timestamp
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (jornada_id, codigo) [unique]
    (cliente_destino_id, estado)
    (almacen_destino_id, estado)
  }
}

Table ticket_precios {
  id bigint [pk, increment]
  ticket_id bigint [not null, ref: > tickets_despacho.id]
  tipo_pollo_id bigint [not null, ref: > tipos_pollo.id]
  precio_historial_id bigint [not null, ref: > precios_historial.id]
  precio_kg decimal(12,4) [not null]
  origen_precio varchar(30) [not null]
  congelado_por bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]

  indexes {
    (ticket_id, tipo_pollo_id) [unique]
  }
}

Table lecturas_balanza {
  id bigint [pk, increment]
  balanza_id bigint [not null, ref: > balanzas.id]
  peso_kg decimal(12,3) [not null]
  trama_cruda varchar(500)
  modo_conexion varchar(20)
  dispositivo varchar(180)
  capturada_at timestamp [not null]
  capturada_por bigint [not null, ref: > usuarios.id]

  indexes {
    (balanza_id, capturada_at)
  }
}

Table pesadas {
  id bigint [pk, increment]
  ticket_id bigint [not null, ref: > tickets_despacho.id]
  numero bigint [not null]
  tipo_pollo_id bigint [not null, ref: > tipos_pollo.id]
  condicion_pollo varchar(20) [not null, default: 'VIVO']
  sexo sexo_pollo [not null, default: 'MACHO']
  tipo_java_id bigint [not null, ref: > tipos_java.id]
  lectura_balanza_id bigint [ref: - lecturas_balanza.id]
  proveedor_origen_id bigint [ref: > terceros.id]
  almacen_origen_id bigint [ref: > almacenes.id]
  vehiculo_id bigint [ref: > vehiculos.id]
  programacion_recepcion_detalle_id bigint [ref: > programacion_recepcion_detalles.id]
  placa_snapshot varchar(20)
  origen_peso origen_peso [not null]
  aves_por_java int [not null]
  cantidad_javas int [not null]
  cantidad_aves int [not null]
  peso_java_kg_snapshot decimal(12,3) [not null]
  peso_leido_kg decimal(12,3) [not null]
  peso_bruto_kg decimal(12,3) [not null]
  tara_total_kg decimal(12,3) [not null]
  peso_neto_kg decimal(12,3) [not null]
  pesada_at timestamp [not null]
  estado estado_pesada [not null, default: 'ACTIVA']
  anulada_por bigint [ref: > usuarios.id]
  anulada_at timestamp
  motivo_anulacion varchar(250)
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (ticket_id, numero) [unique]
    (programacion_recepcion_detalle_id, pesada_at)
    (proveedor_origen_id, pesada_at)
    (almacen_origen_id, pesada_at)
    (tipo_pollo_id, pesada_at)
    (sexo, pesada_at)
  }
}

Table movimientos_inventario {
  id bigint [pk, increment]
  sucursal_id bigint [not null, ref: > sucursales.id]
  ticket_id bigint [ref: > tickets_despacho.id]
  tipo tipo_movimiento [not null]
  almacen_origen_id bigint [ref: > almacenes.id]
  almacen_destino_id bigint [ref: > almacenes.id]
  tercero_origen_id bigint [ref: > terceros.id]
  tercero_destino_id bigint [ref: > terceros.id]
  estado estado_movimiento [not null, default: 'BORRADOR']
  fecha_hora timestamp [not null]
  confirmado_por bigint [ref: > usuarios.id]
  confirmado_at timestamp
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (ticket_id, tipo)
    (almacen_origen_id, fecha_hora)
    (almacen_destino_id, fecha_hora)
  }
}

Table movimiento_detalles {
  id bigint [pk, increment]
  movimiento_id bigint [not null, ref: > movimientos_inventario.id]
  pesada_id bigint [ref: - pesadas.id]
  tipo_pollo_id bigint [not null, ref: > tipos_pollo.id]
  cantidad_aves int [not null]
  peso_neto_kg decimal(12,3) [not null]
  created_at timestamp [not null]

  indexes {
    (movimiento_id, tipo_pollo_id)
  }
}

Table existencias_almacen {
  almacen_id bigint [not null, ref: > almacenes.id]
  tipo_pollo_id bigint [not null, ref: > tipos_pollo.id]
  cantidad_aves int [not null, default: 0]
  peso_neto_kg decimal(14,3) [not null, default: 0]
  updated_at timestamp [not null]

  indexes {
    (almacen_id, tipo_pollo_id) [pk]
  }
}

Table comprobantes {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  tercero_id bigint [not null, ref: > terceros.id]
  operacion operacion_comprobante [not null]
  tipo_documento varchar(30) [not null, default: 'INTERNO']
  codigo varchar(50) [not null]
  origen_codigo origen_codigo_comprobante [not null]
  fecha_emision date [not null]
  fecha_vencimiento date
  moneda char(3) [not null, default: 'PEN']
  subtotal decimal(14,2) [not null]
  impuesto decimal(14,2) [not null, default: 0]
  total decimal(14,2) [not null]
  saldo_pendiente decimal(14,2) [not null]
  estado estado_comprobante [not null, default: 'BORRADOR']
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (empresa_id, codigo) [unique]
    (tercero_id, fecha_emision)
  }
}

Table comprobante_detalles {
  id bigint [pk, increment]
  comprobante_id bigint [not null, ref: > comprobantes.id]
  tipo_pollo_id bigint [ref: > tipos_pollo.id]
  descripcion varchar(250) [not null]
  cantidad_aves int
  peso_neto_kg decimal(12,3)
  precio_kg decimal(12,4)
  subtotal decimal(14,2) [not null]
  created_at timestamp [not null]
}

Table comprobante_tickets {
  comprobante_id bigint [not null, ref: > comprobantes.id]
  ticket_id bigint [not null, ref: > tickets_despacho.id]
  importe_aplicado decimal(14,2) [not null]

  indexes {
    (comprobante_id, ticket_id) [pk]
  }
}

Table comprobante_pesadas {
  comprobante_id bigint [not null, ref: > comprobantes.id]
  pesada_id bigint [not null, ref: > pesadas.id]
  importe_aplicado decimal(14,2) [not null]

  indexes {
    (comprobante_id, pesada_id) [pk]
  }
}

Table pagos {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  tercero_id bigint [not null, ref: > terceros.id]
  direccion direccion_pago [not null]
  fecha_hora timestamp [not null]
  metodo varchar(40) [not null]
  referencia varchar(100)
  moneda char(3) [not null, default: 'PEN']
  importe decimal(14,2) [not null]
  observaciones text
  created_by bigint [not null, ref: > usuarios.id]
  created_at timestamp [not null]

  indexes {
    (tercero_id, fecha_hora)
  }
}

Table pago_aplicaciones {
  pago_id bigint [not null, ref: > pagos.id]
  comprobante_id bigint [not null, ref: > comprobantes.id]
  importe_aplicado decimal(14,2) [not null]
  created_at timestamp [not null]

  indexes {
    (pago_id, comprobante_id) [pk]
  }
}

Table auditoria_eventos {
  id bigint [pk, increment]
  empresa_id bigint [not null, ref: > empresas.id]
  usuario_id bigint [ref: > usuarios.id]
  entidad varchar(80) [not null]
  entidad_id varchar(80) [not null]
  accion varchar(40) [not null]
  datos_antes json
  datos_despues json
  direccion_ip varchar(45)
  created_at timestamp [not null]

  indexes {
    (empresa_id, entidad, entidad_id)
    (usuario_id, created_at)
  }
}
